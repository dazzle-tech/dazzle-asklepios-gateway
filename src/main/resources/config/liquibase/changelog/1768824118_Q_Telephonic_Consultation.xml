<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="QA000000000014" author="qais">

    <createTable tableName="telephonic_consultation">

      <column name="id" type="bigint" autoIncrement="true" startWith="1">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="patient_id" type="bigint">
        <constraints nullable="false"
                     foreignKeyName="fk_patient"
                     referencedTableName="patients"
                     referencedColumnNames="id"/>
      </column>

      <column name="encounter_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="practitioner_id" type="bigint">
        <constraints nullable="false"
                     foreignKeyName="fk_practitioner_patient_physician"
                     referencedTableName="practitioner"
                     referencedColumnNames="id"/>
      </column>

      <column name="date_of_call" type="timestamp">
        <constraints nullable="false"/>
      </column>

      <column name="consultation_content" type="text">
        <constraints nullable="false"/>
      </column>

      <column name="approval_number" type="bigint"/>

      <column name="notes" type="text"/>

      <column name="extra_documentation" type="text"/>

      <column name="status" type="varchar(50)">
        <constraints nullable="false"/>
      </column>

      <column name="cancellation_reason" type="varchar(255)"/>

      <column name="cancelled_at" type="timestamp"/>

      <column name="cancelled_by" type="varchar(50)"/>

      <column name="created_by" type="varchar(50)">
        <constraints nullable="false"/>
      </column>

      <column name="created_date" type="timestamp" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>

      <column name="last_modified_by" type="varchar(50)"/>

      <column name="last_modified_date" type="timestamp"/>

    </createTable>

    <addForeignKeyConstraint
      baseTableName="telephonic_consultation"
      baseColumnNames="encounter_id"
      referencedTableName="patient_encounters"
      referencedColumnNames="id"
      constraintName="fk_telephonic_consultation_encounter"/>

    <addUniqueConstraint
      tableName="telephonic_consultation"
      columnNames="approval_number"
      constraintName="ux_telephonic_consultation_approval_number"
    />

  </changeSet>

</databaseChangeLog>
