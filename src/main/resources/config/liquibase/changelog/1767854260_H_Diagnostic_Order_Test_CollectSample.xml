<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
  <changeSet id="H000000000000MD_DIAG_COLLECTED_SAMPLES" author="hanan253yahya">

    <createTable tableName="diagnostic_order_test_collected_samples">
      <column name="id" type="bigint" autoIncrement="true" startWith="1500">
        <constraints nullable="false" primaryKey="true"/>
      </column>

      <column name="order_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="order_test_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="unit" type="text">
        <constraints nullable="false"/>
      </column>

      <column name="quantity" type="decimal(19,2)">
        <constraints nullable="false"/>
      </column>

      <column name="collected_at" type="timestamp">
        <constraints nullable="false"/>
      </column>

      <!-- auditing -->
      <column name="created_date" type="timestamp"/>
      <column name="created_by" type="varchar(50)"/>
      <column name="last_modified_by" type="varchar(50)"/>
      <column name="last_modified_date" type="timestamp"/>
    </createTable>

    <!-- FK: order_test_id -> diagnostic_order_tests(id) -->
    <addForeignKeyConstraint
      constraintName="fk_dot_cs_order_test_id"
      baseTableName="diagnostic_order_test_collected_samples"
      baseColumnNames="order_test_id"
      referencedTableName="diagnostic_order_tests"
      referencedColumnNames="id"
    />

    <!-- FK: order_id -> diagnostic_orders(id) -->
    <addForeignKeyConstraint
      constraintName="fk_dot_cs_order_id"
      baseTableName="diagnostic_order_test_collected_samples"
      baseColumnNames="order_id"
      referencedTableName="diagnostic_orders"
      referencedColumnNames="id"
    />



    <dropDefaultValue
      tableName="diagnostic_order_test_collected_samples"
      columnName="created_date"
      columnDataType="${datetimeType}"/>
  </changeSet>

</databaseChangeLog>
