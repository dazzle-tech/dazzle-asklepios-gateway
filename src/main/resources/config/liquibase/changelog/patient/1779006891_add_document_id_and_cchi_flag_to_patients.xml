<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">


  <changeSet id="bs00000000000039" author="batool">

    <addColumn tableName="patients">

      <column name="is_cchi_patient" type="boolean" defaultValueBoolean="false">
        <constraints nullable="false"/>
      </column>

      <column name="document_id" type="varchar(100)">
        <constraints nullable="true"/>
      </column>

    </addColumn>

    <addUniqueConstraint
      tableName="patients"
      columnNames="document_id"
      constraintName="uk_patients_document_id"/>

  </changeSet>
</databaseChangeLog>
