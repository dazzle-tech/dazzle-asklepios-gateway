<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
http://www.liquibase.org/xml/ns/dbchangelog
http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="QA0000000000024_add_blood_group_and_patient_conditions" author="qais">
    <preConditions onFail="MARK_RAN">
      <and>
        <not>
          <columnExists tableName="patients" columnName="blood_group"/>
        </not>
        <not>
          <columnExists tableName="patients" columnName="patient_conditions"/>
        </not>
      </and>
    </preConditions>
    <addColumn tableName="patients">
      <column name="blood_group" type="varchar(20)"/>
      <column name="patient_conditions" type="text"/>
    </addColumn>
  </changeSet>

</databaseChangeLog>
