<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">



  <changeSet id="H000000000000MD_DIAG_TESTS_REQUEST" author="hanan253yahya">

    <createTable tableName="diagnostic_test_requests">
      <column name="id" type="bigint" autoIncrement="true" startWith="1500">
        <constraints nullable="false" primaryKey="true"/>
      </column>


      <column name="status" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
      <column name="type" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
      <column name="name" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
      <column name="indication" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="rejected_date" type="timestamp"/>
      <column name="approved_date" type="timestamp"/>

      <column name="rejected_by" type="varchar(50)"/>
      <column name="approved_by" type="varchar(50)"/>

      <column name="rejected_reason" type="varchar(200)"/>


      <column name="from_department_id" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column name="from_facility_id" type="bigint">
        <constraints nullable="false"/>
      </column>
      <!-- auditing -->
      <column name="created_date" type="timestamp" defaultValue="now()">
        <constraints nullable="false"/>
      </column>
      <column name="created_by" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
      <column name="last_modified_by" type="varchar(50)"/>
      <column name="last_modified_date" type="timestamp"/>
    </createTable>



    <!-- FK: from_department_id -> department(id) -->
    <addForeignKeyConstraint
      constraintName="fk_dtr_from_department"
      baseTableName="diagnostic_test_requests"
      baseColumnNames="from_department_id"
      referencedTableName="department"
      referencedColumnNames="id"

    />
    <addForeignKeyConstraint
      constraintName="fk_dtr_from_facility"
      baseTableName="diagnostic_test_requests"
      baseColumnNames="from_facility_id"
      referencedTableName="facility"
      referencedColumnNames="id"

    />

  </changeSet>

</databaseChangeLog>
