<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">


  <changeSet id="H000000000004_REPORT_IMAGE_STATUS_LOG" author="hanan253yahya">
    <createTable tableName="diagnostic_order_tests_report_image_status_log">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="report_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="status_date" type="timestamp">
        <constraints nullable="false"/>
      </column>

      <column name="status_by" type="varchar(50)"/>

      <column name="status_value" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint
      baseTableName="diagnostic_order_tests_report_image_status_log"
      baseColumnNames="report_id"
      constraintName="fk_rep_img_status_log_report"
      referencedTableName="diagnostic_order_tests_report"
      referencedColumnNames="id"
    />

    <createIndex tableName="diagnostic_order_tests_report_image_status_log"
                 indexName="idx_rep_img_status_log_report_id">
      <column name="report_id"/>
    </createIndex>
  </changeSet>

  <changeSet id="H000000000004_REPORT_IMAGE_STATUS_LOG_TRIGGERS" author="hanan253yahya" runOnChange="true">
    <sqlFile path="config/liquibase/sql/Report_Image_Status_Log.sql"
             relativeToChangelogFile="false"
             splitStatements="false"/>
  </changeSet>

</databaseChangeLog>
