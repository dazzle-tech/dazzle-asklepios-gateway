<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
  <changeSet id="APP_00000000000034_ADD_WAITING_FIELDS_TO_APPOINTMENT" author="Sondos">
    <addColumn tableName="appointment">
      <column name="booking_group_id" type="bigint"/>
      <column name="waiting_list_id" type="bigint"/>
    </addColumn>

    <addForeignKeyConstraint
      baseTableName="appointment"
      baseColumnNames="booking_group_id"
      referencedTableName="appointment_booking_group"
      referencedColumnNames="id"
      constraintName="fk_appointment_booking_group"/>

    <addForeignKeyConstraint
      baseTableName="appointment"
      baseColumnNames="waiting_list_id"
      referencedTableName="appointment_waiting_list"
      referencedColumnNames="id"
      constraintName="fk_appointment_waiting_list"/>

    <createIndex tableName="appointment" indexName="idx_appointment_booking_group">
      <column name="booking_group_id"/>
    </createIndex>

    <createIndex tableName="appointment" indexName="idx_appointment_waiting_list">
      <column name="waiting_list_id"/>
    </createIndex>

    <createIndex tableName="appointment" indexName="idx_appointment_waiting_candidate">
      <column name="facility_id"/>
      <column name="department_id"/>
      <column name="status"/>
      <column name="booking_mode"/>
      <column name="start_datetime"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
