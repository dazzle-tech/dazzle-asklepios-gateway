<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="H-04-patient-merge-master-decisions" author="hanan253yahya">

    <createTable tableName="patient_merge_master_decisions">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="merge_log_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="entity_name" type="varchar(100)">
        <constraints nullable="false"/>
      </column>

      <column name="table_name" type="varchar(100)">
        <constraints nullable="false"/>
      </column>

      <column name="from_record_id" type="bigint"/>

      <column name="to_record_id" type="bigint"/>

      <column name="match_key" type="varchar(255)"/>

      <column name="field_name" type="varchar(100)"/>

      <column name="field_label" type="varchar(150)"/>

      <column name="from_value" type="varchar(2000)"/>

      <column name="to_value" type="varchar(2000)"/>



      <column name="final_decision" type="varchar(50)">
        <constraints nullable="false"/>
      </column>

      <column name="selected_value" type="varchar(2000)">
        <constraints nullable="false"/>
      </column>
      <column name="created_by" type="varchar(100)" >
        <constraints nullable="false"/>
      </column>
      <column name="created_date" type="timestamp" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>
      <column name="last_modified_by" type="varchar(50)"/>
      <column name="last_modified_date" type="timestamp"/>
    </createTable>

    <addForeignKeyConstraint
      baseTableName="patient_merge_master_decisions"
      baseColumnNames="merge_log_id"
      referencedTableName="patient_merge_logs"
      referencedColumnNames="id"
      constraintName="fk_patient_merge_master_decisions_merge_log"/>

    <createIndex tableName="patient_merge_master_decisions" indexName="idx_patient_merge_master_decisions_merge_log_id">
      <column name="merge_log_id"/>
    </createIndex>

    <createIndex tableName="patient_merge_master_decisions" indexName="idx_patient_merge_master_decisions_entity">
      <column name="entity_name"/>
      <column name="table_name"/>
    </createIndex>


    <createIndex tableName="patient_merge_master_decisions"
                 indexName="idx_patient_merge_master_decisions_merge_entity">
      <column name="merge_log_id"/>
      <column name="entity_name"/>
    </createIndex>
    <addUniqueConstraint
      tableName="patient_merge_master_decisions"
      columnNames="merge_log_id, entity_name, field_name, match_key"
      constraintName="uq_patient_merge_master_decisions_unique_field"/>
  </changeSet>
</databaseChangeLog>
