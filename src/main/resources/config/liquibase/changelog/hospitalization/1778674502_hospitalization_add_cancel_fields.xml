<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="F00000000000006_add_cancel_fields_to_hospitalization" author="farouk">

    <addColumn tableName="hospitalizations">

      <column name="status" type="varchar(50)" defaultValue="ACTIVE">
        <constraints nullable="false"/>
      </column>

      <column name="cancelled_by" type="varchar(50)"/>

      <column name="cancelled_date" type="timestamp"/>

      <column name="cancellation_reason" type="text"/>

    </addColumn>

    <sql><![CDATA[
      ALTER TABLE hospitalizations
      DROP CONSTRAINT IF EXISTS ux_hospitalizations_patient_facility_date_reason;
      ]]></sql>

    <sql><![CDATA[
      CREATE UNIQUE INDEX ux_hospitalizations_patient_facility_date_reason
        ON hospitalizations (
                             patient_id,
                             lower(facility),
                             date_of_admission,
                             lower(reason)
          )
        WHERE status <> 'CANCELLED';
      ]]></sql>

  </changeSet>

</databaseChangeLog>
