<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="1782179241-NotificationData" author="SondosAbdAlaal">

    <loadData
      file="config/liquibase/data/notification/notification_header_default_v2.csv"
      separator=";"
      tableName="notification_header"
      schemaName="notification"
    >
      <column name="id" type="NUMERIC"/>
      <column name="facility_id" type="NUMERIC"/>
      <column name="code" type="STRING"/>
      <column name="name" type="STRING"/>
      <column name="description" type="STRING"/>
      <column name="module" type="STRING"/>
      <column name="category" type="STRING"/>
      <column name="priority" type="STRING"/>
      <column name="is_active" type="BOOLEAN"/>
      <column name="created_by" type="STRING"/>
      <column name="last_modified_by" type="STRING"/>
    </loadData>

  </changeSet>
  <changeSet id="1782181182_notificationTemplateData" author="Sondos Abd-Alaal">
    <loadData
      file="config/liquibase/data/notification/notification_template_default_v2.csv"
      separator=";"
      tableName="notification_template"
      schemaName="notification"
    >

      <column name="id" type="NUMERIC"/>
      <column name="notification_header_id" type="NUMERIC"/>
      <column name="channel" type="STRING"/>
      <column name="language" type="STRING"/>
      <column name="subject" type="STRING"/>
      <column name="title" type="STRING"/>
      <column name="body" type="STRING"/>
      <column name="to_recipient_rule" type="STRING"/>
      <column name="cc_recipient_rule" type="STRING"/>
      <column name="bcc_recipient_rule" type="STRING"/>
      <column name="phone_recipient_rule" type="STRING"/>
      <column name="is_active" type="BOOLEAN"/>
      <column name="created_by" type="STRING"/>
      <column name="last_modified_by" type="STRING"/>
    </loadData>
  </changeSet>

</databaseChangeLog>
