<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="F00000000000004_add_cancel_fields_to_patient_problems" author="farouk">

    <renameColumn
      tableName="patient_problems"
      oldColumnName="status"
      newColumnName="condition_status"
      columnDataType="varchar(50)"/>

    <addColumn tableName="patient_problems">

      <column name="status" type="varchar(50)" defaultValue="ACTIVE">
        <constraints nullable="false"/>
      </column>

      <column name="cancelled_by" type="varchar(50)"/>

      <column name="cancelled_date" type="timestamp"/>

      <column name="cancellation_reason" type="text"/>

    </addColumn>

    <sql><![CDATA[
      DROP INDEX IF EXISTS ux_patient_problems_patient_condition_date;
      ALTER TABLE patient_problems
      DROP CONSTRAINT IF EXISTS ux_patient_problems_patient_condition_date;
      ]]></sql>

    <sql><![CDATA[
      CREATE UNIQUE INDEX ux_patient_problems_patient_condition_date
        ON patient_problems (
                             patient_id,
                             lower(condition),
                             date_of_diagnosis
          )
        WHERE status <> 'CANCELLED';
      ]]></sql>

  </changeSet>

</databaseChangeLog>
