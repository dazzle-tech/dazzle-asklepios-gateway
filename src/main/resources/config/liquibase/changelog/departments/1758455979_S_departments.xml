<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="00000000000018" author="Sondos">

    <createTable tableName="department">
      <column name="id" type="bigint" autoIncrement="true" startWith="5000">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="facility_id" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column name="name" type="varchar(100)">
        <constraints nullable="false"/>
      </column>
      <column name="created_by" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
      <column name="created_date" type="timestamp"/>
      <column name="type" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
      <column name="last_modified_by" type="varchar(50)"/>
      <column name="last_modified_date" type="timestamp"/>
      <column name="appointable" type="boolean"/>
      <column name="code" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
      <column name="phone_number" type="varchar(50)"/>
      <column name="email" type="varchar(100)"/>
      <column name="encounter_type" type="varchar(50)"/>
      <column name="is_active" type="boolean"/>
      <column name="has_medical_sheets" type="boolean" defaultValueBoolean="false"/>
      <column name="has_nurse_medical_sheets" type="boolean" defaultValueBoolean="false"/>

      <column name="parallel_capacity_enabled" type="boolean" defaultValueBoolean="false">
        <constraints nullable="false"/>
      </column>
      <column name="parallel_capacity_value" type="int" defaultValueNumeric="1"/>
      <column name="default_duration_minutes" type="int"/>
      <column name="default_buffer_before_minutes" type="int" defaultValueNumeric="0"/>
      <column name="default_buffer_after_minutes" type="int" defaultValueNumeric="0"/>
      <column name="require_practitioner" type="boolean" defaultValueBoolean="false"/>
      <column name="require_billing" type="boolean" defaultValueBoolean="false"/>
      <column name="require_pre_assessment" type="boolean" defaultValueBoolean="false"/>
    </createTable>

    <addForeignKeyConstraint
      baseTableName="department"
      baseColumnNames="facility_id"
      referencedTableName="facility"
      referencedColumnNames="id"
      constraintName="fk_department_facility"/>


    <sql>
      ALTER TABLE department
        ADD CONSTRAINT chk_department_parallel_capacity
          CHECK (
            parallel_capacity_enabled = false
              OR (parallel_capacity_enabled = true AND parallel_capacity_value IS NOT NULL AND parallel_capacity_value >= 1)
            );
    </sql>

    <sql>
      ALTER TABLE department
        ADD CONSTRAINT chk_department_appointable_requirements
          CHECK (
            appointable = false
              OR (
              appointable = true
                AND default_duration_minutes IS NOT NULL AND default_duration_minutes > 0
                AND default_buffer_before_minutes IS NOT NULL AND default_buffer_before_minutes >= 0
                AND default_buffer_after_minutes IS NOT NULL AND default_buffer_after_minutes >= 0
                AND require_practitioner IS NOT NULL
                AND require_billing IS NOT NULL
                AND require_pre_assessment IS NOT NULL
              )
            );
    </sql>

  </changeSet>

</databaseChangeLog>
