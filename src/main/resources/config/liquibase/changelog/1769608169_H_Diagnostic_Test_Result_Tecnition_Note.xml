<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <!-- ===================================================== -->
  <!-- Technician Notes (child table of diagnostic_order_tests_result) -->
  <!-- ===================================================== -->
  <changeSet
    id="H000000000000MD_DIAG_RESULT_TECHNICIAN_NOTES"
    author="hanan253yahya">

    <!-- ========== Table ========== -->
    <createTable tableName="diagnostic_order_test_result_technician_notes">
      <column name="id" type="bigint" autoIncrement="true" startWith="1500">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <!-- Parent references -->
      <column name="order_test_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="result_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <!-- Note content -->
      <column name="note" type="text">
        <constraints nullable="false"/>
      </column>

      <!-- Auditing -->
      <column name="created_date" type="timestamp" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>
      <column name="created_by" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
      <column name="last_modified_by" type="varchar(50)"/>
      <column name="last_modified_date" type="timestamp"/>
    </createTable>

    <!-- ========== Foreign Keys ========== -->

    <!-- order_test_id -> diagnostic_order_tests(id) -->
    <addForeignKeyConstraint
      constraintName="fk_dotr_tn_order_test_id"
      baseTableName="diagnostic_order_test_result_technician_notes"
      baseColumnNames="order_test_id"
      referencedTableName="diagnostic_order_tests"
      referencedColumnNames="id"
    />

    <!-- result_id -> diagnostic_order_tests_result(id) -->
    <addForeignKeyConstraint
      constraintName="fk_dotr_tn_result_id"
      baseTableName="diagnostic_order_test_result_technician_notes"
      baseColumnNames="result_id"
      referencedTableName="diagnostic_order_tests_result"
      referencedColumnNames="id"
    />

    <!-- ========== Indexes ========== -->
    <createIndex
      indexName="idx_dotr_tn_result_id"
      tableName="diagnostic_order_test_result_technician_notes">
      <column name="result_id"/>
    </createIndex>

    <createIndex
      indexName="idx_dotr_tn_order_test_id"
      tableName="diagnostic_order_test_result_technician_notes">
      <column name="order_test_id"/>
    </createIndex>


  </changeSet>


</databaseChangeLog>
