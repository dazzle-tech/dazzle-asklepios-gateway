<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <!-- ... your existing changeSets ... -->

  <!-- ===================================================== -->
  <!-- Technician Notes (child table of diagnostic_order_tests) -->
  <!-- ===================================================== -->
  <changeSet id="H000000000000MD_DIAG_TECHNICIAN_NOTES" author="hanan253yahya">

    <createTable tableName="diagnostic_order_test_technician_notes">
      <column name="id" type="bigint" autoIncrement="true" startWith="1500">
        <constraints nullable="false" primaryKey="true"/>
      </column>

      <!-- Parent references -->
      <column name="order_test_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="order_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <!-- Note content -->
      <column name="note" type="text">
        <constraints nullable="false"/>
      </column>


      <!-- auditing (optional - keep consistent with your project) -->
      <column name="created_date" type="timestamp" defaultValue="now()">
        <constraints nullable="false"/>
      </column>
      <column name="created_by" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
      <column name="last_modified_by" type="varchar(50)"/>
      <column name="last_modified_date" type="timestamp"/>
    </createTable>

    <!-- FK: order_test_id -> diagnostic_order_tests(id) -->
    <addForeignKeyConstraint
      constraintName="fk_dot_tn_order_test_id"
      baseTableName="diagnostic_order_test_technician_notes"
      baseColumnNames="order_test_id"
      referencedTableName="diagnostic_order_tests"
      referencedColumnNames="id"
    />

    <!-- FK: order_id -> diagnostic_orders(id) -->
    <addForeignKeyConstraint
      constraintName="fk_dot_tn_order_id"
      baseTableName="diagnostic_order_test_technician_notes"
      baseColumnNames="order_id"
      referencedTableName="diagnostic_orders"
      referencedColumnNames="id"
    />


  </changeSet>

</databaseChangeLog>
