<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="APP_Log_00000000000002" author="Rawan-Yahya">
    <addColumn tableName="appointment_log">
      <column name="require_confirmation" type="boolean"/>
    </addColumn>
    <addColumn tableName="appointment_log">
      <column name="require_practitioner" type="boolean"/>
    </addColumn>

  </changeSet>

  <changeSet id="APP_Log_00000000000003" author="Rawan-Yahya">
    <addDefaultValue
      tableName="appointment_log"
      columnName="require_confirmation"
      defaultValueBoolean="true"/>

    <update tableName="appointment_log">
      <column name="require_confirmation" valueBoolean="true"/>
      <where>require_confirmation IS NULL</where>
    </update>

    <addNotNullConstraint
      tableName="appointment_log"
      columnName="require_confirmation"
      columnDataType="boolean"/>

    <addDefaultValue
      tableName="appointment_log"
      columnName="require_practitioner"
      defaultValueBoolean="false"/>

    <update tableName="appointment_log">
      <column name="require_practitioner" valueBoolean="false"/>
      <where>require_practitioner IS NULL</where>
    </update>

    <addNotNullConstraint
      tableName="appointment_log"
      columnName="require_practitioner"
      columnDataType="boolean"/>
  </changeSet>

</databaseChangeLog>
