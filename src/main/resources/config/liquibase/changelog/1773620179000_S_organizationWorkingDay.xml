<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
  <changeSet id="100000000000067_WORKING_DAY" author="Sondos">

    <createTable tableName="organization_working_day">
      <column name="id" type="bigint" autoIncrement="true" startWith="5000">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="organization_definition_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="day_of_week" type="varchar(50)">
        <constraints nullable="false"/>
      </column>

      <column name="is_working" type="boolean" defaultValueBoolean="true">
        <constraints nullable="false"/>
      </column>

    </createTable>

    <addForeignKeyConstraint
      baseTableName="organization_working_day"
      baseColumnNames="organization_definition_id"
      constraintName="fk_org_working_day_org_definition"
      referencedTableName="organization_definition"
      referencedColumnNames="id"/>

    <addUniqueConstraint
      tableName="organization_working_day"
      columnNames="organization_definition_id, day_of_week"
      constraintName="uk_org_working_day_org_day"/>

  </changeSet>
</databaseChangeLog>
