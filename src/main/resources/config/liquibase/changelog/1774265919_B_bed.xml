<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="bs000000000033" author="batool">

    <createTable tableName="beds">

      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="room_id" type="bigint">
        <constraints nullable="false"
                     referencedTableName="rooms"
                     referencedColumnNames="id"
                     foreignKeyName="fk_bed_room"/>
      </column>

      <column name="name" type="varchar(100)">
        <constraints nullable="false"/>
      </column>

      <column name="location_details" type="text"/>

      <column name="type" type="varchar(50)">
        <constraints nullable="false"/>
      </column>

      <column name="status" type="varchar(50)" defaultValue="EMPTY">
        <constraints nullable="false"/>
      </column>

      <column name="created_date" type="timestamp" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>

      <column name="is_active" type="boolean" defaultValueBoolean="true">
        <constraints nullable="false"/>
      </column>

      <column name="created_by" type="varchar(50)">
        <constraints nullable="false"/>
      </column>

      <column name="last_modified_by" type="varchar(50)"/>
      <column name="last_modified_date" type="timestamp"/>

    </createTable>

    <createIndex tableName="beds" indexName="idx_bed_room">
      <column name="room_id"/>
    </createIndex>

    <createIndex indexName="uk_bed_room_name_ci"
                 tableName="beds"
                 unique="true">
      <column name="room_id"/>
      <column name="name"/>
    </createIndex>

  </changeSet>

</databaseChangeLog>
