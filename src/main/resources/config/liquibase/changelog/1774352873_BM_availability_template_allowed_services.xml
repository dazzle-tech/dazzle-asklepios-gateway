<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="
                     http://www.liquibase.org/xml/ns/dbchangelog
                     http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="availability_template_allowed_services" author="BushraMashaiekh">

    <createTable tableName="availability_template_allowed_services">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="template_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="template_interval_id" type="bigint"/>

      <column name="day_of_week" type="varchar(20)"/>

      <column name="service" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint
      baseTableName="availability_template_allowed_services"
      baseColumnNames="template_id"
      referencedTableName="availability_template"
      referencedColumnNames="id"
      constraintName="fk_allowed_service_template"/>

    <addForeignKeyConstraint
      baseTableName="availability_template_allowed_services"
      baseColumnNames="template_interval_id"
      referencedTableName="availability_template_interval"
      referencedColumnNames="id"
      constraintName="fk_allowed_service_interval"/>

    <!-- Unique when interval is NULL -->
    <sql>
      CREATE UNIQUE INDEX uq_allowed_service_template_day_service_no_interval
        ON availability_template_allowed_services (template_id, service)
        WHERE template_interval_id IS NULL;
    </sql>

    <!-- Unique when interval is NOT NULL -->
    <sql>
      CREATE UNIQUE INDEX uq_allowed_service_interval_day_service
        ON availability_template_allowed_services (template_interval_id, day_of_week, service)
        WHERE template_interval_id IS NOT NULL;
    </sql>

  </changeSet>

</databaseChangeLog>
