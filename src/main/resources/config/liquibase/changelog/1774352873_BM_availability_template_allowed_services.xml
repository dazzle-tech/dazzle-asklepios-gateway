<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="
                     http://www.liquibase.org/xml/ns/dbchangelog
                     http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

<changeSet id="availability_template_allowed_services" author="BushraMashaiekh">

    <createTable tableName="availability_template_allowed_services">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="template_id" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column name="template_interval_id" type="bigint"/>
      <column name="service" type="bigint"/>
    </createTable>

    <addForeignKeyConstraint
      baseTableName="availability_template_allowed_services"
      baseColumnNames="template_id"
      referencedTableName="availability_template"
      referencedColumnNames="id"
      constraintName="fk_allowed_service_template"/>

    <addForeignKeyConstraint
      baseTableName="availability_template_allowed_services"
      baseColumnNames="template_interval_id"
      referencedTableName="availability_template_interval"
      referencedColumnNames="id"
      constraintName="fk_allowed_service_interval"/>

  </changeSet>

</databaseChangeLog>
