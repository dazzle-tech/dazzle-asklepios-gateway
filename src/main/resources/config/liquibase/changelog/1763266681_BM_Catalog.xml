<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <changeSet id="BM0000000000015" author="BushraMashaiekh">
    <createTable tableName="catalog">
      <column name="id" type="bigint" autoIncrement="true" startWith="100">
        <constraints primaryKey="true" nullable="false" primaryKeyName="pk_catalog"/>
      </column>
      <column name="name" type="varchar(150)">
        <constraints nullable="false"/>
      </column>
      <column name="description" type="text"/>
      <column name="type" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
      <column name="facility_id" type="bigint">
        <constraints foreignKeyName="fk_catalog_facility" referencedTableName="facility" referencedColumnNames="id"/>
      </column>
      <column name="department_id" type="bigint">
        <constraints  foreignKeyName="fk_catalog_department" referencedTableName="department" referencedColumnNames="id"/>
      </column>
      <column name="appointable" type="boolean"/>
      <column name="parallel_capacity_value" type="int" defaultValueNumeric="1">
        <constraints nullable="false"/>
      </column>
      <column name="default_duration_minutes" type="int"/>
      <column name="default_buffer_before_minutes" type="int" defaultValueNumeric="0"/>
      <column name="default_buffer_after_minutes" type="int" defaultValueNumeric="0"/>

    </createTable>

    <createIndex indexName="idx_catalog_department" tableName="catalog">
      <column name="department_id"/>
    </createIndex>
    <createIndex indexName="idx_catalog_facility" tableName="catalog">
      <column name="facility_id"/>
    </createIndex>
    <sql>
      ALTER TABLE catalog
        ADD CONSTRAINT chk_catalog_appointable_requirements
          CHECK (
            appointable = false
              OR (
              appointable = true
                AND default_duration_minutes IS NOT NULL AND default_duration_minutes > 0
                AND default_buffer_before_minutes IS NOT NULL AND default_buffer_before_minutes >= 0
                AND default_buffer_after_minutes IS NOT NULL AND default_buffer_after_minutes >= 0
              )
            );
    </sql>
  </changeSet>
  </databaseChangeLog>
