<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="bs000000000035" author="batool">

    <createTable tableName="encounter_assign_to_bed">

      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="encounter_id" type="bigint">
        <constraints nullable="false"
                     referencedTableName="patient_encounters"
                     referencedColumnNames="id"
                     foreignKeyName="fk_encounter_assign_bed_encounter"/>
      </column>

      <column name="patient_id" type="bigint">
        <constraints nullable="false"
                     referencedTableName="patients"
                     referencedColumnNames="id"
                     foreignKeyName="fk_encounter_assign_bed_patient"/>
      </column>

      <column name="room_id" type="bigint">
        <constraints nullable="false"
                     referencedTableName="rooms"
                     referencedColumnNames="id"
                     foreignKeyName="fk_encounter_assign_bed_room"/>
      </column>

      <column name="bed_id" type="bigint">
        <constraints nullable="false"
                     referencedTableName="beds"
                     referencedColumnNames="id"
                     foreignKeyName="fk_encounter_assign_bed_bed"/>
      </column>

      <column name="department_id" type="bigint">
        <constraints nullable="false"
                     referencedTableName="department"
                     referencedColumnNames="id"
                     foreignKeyName="fk_encounter_assign_bed_department"/>
      </column>

      <column name="admission_reason" type="text"/>

      <column name="assigned_at" type="timestamp" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>

      <column name="released_at" type="timestamp"/>

      <column name="is_active" type="boolean" defaultValueBoolean="true">
        <constraints nullable="false"/>
      </column>

      <column name="created_date" type="timestamp" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>

      <column name="created_by" type="varchar(50)">
        <constraints nullable="false"/>
      </column>

      <column name="last_modified_by" type="varchar(50)"/>
      <column name="last_modified_date" type="timestamp"/>

    </createTable>

    <createIndex tableName="encounter_assign_to_bed" indexName="idx_encounter_assign_bed_encounter">
      <column name="encounter_id"/>
    </createIndex>

    <createIndex tableName="encounter_assign_to_bed" indexName="idx_encounter_assign_bed_patient">
      <column name="patient_id"/>
    </createIndex>

    <createIndex tableName="encounter_assign_to_bed" indexName="idx_encounter_assign_bed_room">
      <column name="room_id"/>
    </createIndex>

    <createIndex tableName="encounter_assign_to_bed" indexName="idx_encounter_assign_bed_bed">
      <column name="bed_id"/>
    </createIndex>

    <createIndex tableName="encounter_assign_to_bed" indexName="idx_encounter_assign_bed_department">
      <column name="department_id"/>
    </createIndex>

    <sql>
      <![CDATA[
      CREATE UNIQUE INDEX uk_encounter_assign_bed_active_encounter
        ON encounter_assign_to_bed (encounter_id)
        WHERE is_active = true;
      ]]>
    </sql>

    <sql>
      <![CDATA[
      CREATE UNIQUE INDEX uk_encounter_assign_bed_active_bed
        ON encounter_assign_to_bed (bed_id)
        WHERE is_active = true;
      ]]>
    </sql>

    <sql>
      <![CDATA[
      ALTER TABLE encounter_assign_to_bed
        ADD CONSTRAINT ck_encounter_assign_bed_release_logic
          CHECK (
            (is_active = true AND released_at IS NULL)
              OR
            (is_active = false)
            );
      ]]>
    </sql>

  </changeSet>

</databaseChangeLog>
