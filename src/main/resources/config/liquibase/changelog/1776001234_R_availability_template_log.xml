<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="R00000000000009_AVAILABILITY_TEMPLATE_LOG" author="Rawan-Yahya">
    <createTable tableName="availability_template_log">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="template_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="operation_type" type="varchar(10)">
        <constraints nullable="false"/>
      </column>

      <column name="log_date" type="timestamp">
        <constraints nullable="false"/>
      </column>

      <column name="log_by" type="varchar(50)"/>

      <column name="facility_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="department_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="template_name" type="varchar(100)">
        <constraints nullable="false"/>
      </column>
      <column name="template_type" type="varchar(30)">
        <constraints nullable="false"/>
      </column>

      <column name="resource_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="template_color" type="varchar(20)"/>

      <column name="status" type="varchar(20)">
        <constraints nullable="false"/>
      </column>
      <column name="version_no" type="int">
        <constraints nullable="false"/>
      </column>

      <column name="copy_from_template_id" type="bigint"/>
      <column name="parent_template_id" type="bigint"/>

      <column name="duration_minutes" type="int">
        <constraints nullable="false"/>
      </column>
      <column name="default_buffer_before_minutes" type="int">
        <constraints nullable="false"/>
      </column>
      <column name="default_buffer_after_minutes" type="int">
        <constraints nullable="false"/>
      </column>
      <column name="parallel_capacity_value" type="int">
        <constraints nullable="false"/>
      </column>
      <column name="default_service_id" type="bigint"/>
      <column name="number_of_resources_expected" type="int"/>
      <column name="require_practitioner" type="boolean">
        <constraints nullable="false"/>
      </column>
      <column name="default_practitioner_id" type="bigint"/>
      <column name="require_billing" type="boolean">
        <constraints nullable="false"/>
      </column>
      <column name="require_pre_assessment" type="boolean">
        <constraints nullable="false"/>
      </column>

      <column name="allow_patient_portal_booking" type="boolean">
        <constraints nullable="false"/>
      </column>

      <column name="require_confirmation" type="boolean">
        <constraints nullable="false"/>
      </column>

      <column name="financial_details" type="varchar(50)">
        <constraints nullable="false"/>
      </column>

      <column name="working_days" type="json">
        <constraints nullable="false"/>
      </column>

      <column name="is_active" type="boolean">
        <constraints nullable="false"/>
      </column>
      <column name="created_by" type="varchar(50)">
        <constraints nullable="false"/>
      </column>

      <column name="created_date" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="last_modified_by" type="varchar(50)"/>
      <column name="last_modified_date" type="timestamp"/>
    </createTable>

    <addForeignKeyConstraint
      baseTableName="availability_template_log"
      baseColumnNames="template_id"
      constraintName="fk_av_template_log_template"
      referencedTableName="availability_template"
      referencedColumnNames="id"
    />

    <addForeignKeyConstraint
      baseTableName="availability_template_log"
      baseColumnNames="facility_id"
      referencedTableName="facility"
      referencedColumnNames="id"
      constraintName="fk_av_template_log_facility"/>

    <addForeignKeyConstraint
      baseTableName="availability_template_log"
      baseColumnNames="department_id"
      referencedTableName="department"
      referencedColumnNames="id"
      constraintName="fk_av_template_log_department"/>

    <addForeignKeyConstraint
      baseTableName="availability_template_log"
      baseColumnNames="default_practitioner_id"
      referencedTableName="practitioner"
      referencedColumnNames="id"
      constraintName="fk_av_template_log_practitioner"/>

    <addForeignKeyConstraint
      baseTableName="availability_template_log"
      baseColumnNames="default_service_id"
      referencedTableName="service"
      referencedColumnNames="id"
      constraintName="fk_av_template_log_service"/>

    <addForeignKeyConstraint
      baseTableName="availability_template_log"
      baseColumnNames="parent_template_id"
      referencedTableName="availability_template"
      referencedColumnNames="id"
      constraintName="fk_av_template_log_parent"/>

    <addForeignKeyConstraint
      baseTableName="availability_template_log"
      baseColumnNames="copy_from_template_id"
      referencedTableName="availability_template"
      referencedColumnNames="id"
      constraintName="fk_av_template_log_copy"/>

    <createIndex tableName="availability_template_log"
                 indexName="idx_av_template_log_template_id">
      <column name="template_id"/>
    </createIndex>

    <createIndex tableName="availability_template_log"
                 indexName="idx_av_template_log_date">
      <column name="log_date"/>
    </createIndex>
  </changeSet>

  <include file="config/liquibase/sql/availability_template_Log.sql" relativeToChangelogFile="false"/>

</databaseChangeLog>
