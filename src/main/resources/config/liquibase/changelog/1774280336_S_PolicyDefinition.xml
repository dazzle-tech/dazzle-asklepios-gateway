<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="00000000000070_PolicyDefinition" author="Sondos">

    <createTable tableName="policy_definition">
      <column name="id" type="bigint" autoIncrement="true" startWith="5000">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="facility_id" type="bigint"/>
      <column name="code" type="varchar(50)">
        <constraints nullable="false" />
      </column>
      <column name="name" type="varchar(100)">
        <constraints nullable="false"/>
      </column>
      <column name="description" type="varchar(500)"/>
      <column name="is_active" type="boolean" defaultValue="true">
        <constraints nullable="false"/>
      </column>
      <column name="created_by" type="varchar(50)">
        <constraints nullable="false"/>
      </column>
      <column name="created_date" type="timestamp" defaultValue="now()">
      <constraints nullable="false"/>
      </column>
      <column name="last_modified_by" type="varchar(50)"/>
      <column name="last_modified_date" type="timestamp"/>
    </createTable>

    <addForeignKeyConstraint
      baseTableName="policy_definition"
      baseColumnNames="facility_id"
      referencedTableName="facility"
      referencedColumnNames="id"
      constraintName="fk_policy_definition_facility"/>

    <addUniqueConstraint
      tableName="policy_definition"
      columnNames="code"
      constraintName="uk_policy_definition_code"/>


  </changeSet>

</databaseChangeLog>
