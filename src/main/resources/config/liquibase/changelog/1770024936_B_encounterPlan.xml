<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="b00000000000028" author="batool">

    <createTable tableName="encounter_plans">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="patient_id" type="bigint">
        <constraints nullable="false"
                     referencedTableName="patients"
                     referencedColumnNames="id"
                     foreignKeyName="fk_enc_plan_patient"/>
      </column>

      <column name="encounter_id" type="bigint">
        <constraints nullable="true"/>
      </column>

      <column name="plan_instructions" type="text">
        <constraints nullable="false"/>
      </column>

      <column name="created_date" type="timestamp" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>

      <column name="created_by" type="varchar(50)">
        <constraints nullable="false"/>
      </column>

      <column name="last_modified_by" type="varchar(50)"/>
      <column name="last_modified_date" type="timestamp"/>
    </createTable>

    <createIndex tableName="encounter_plans" indexName="idx_enc_plan_patient">
      <column name="patient_id"/>
    </createIndex>

    <createIndex tableName="encounter_plans" indexName="idx_enc_plan_encounter">
      <column name="encounter_id"/>
    </createIndex>

  </changeSet>

</databaseChangeLog>
