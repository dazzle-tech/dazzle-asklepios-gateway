<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="F00000000000003_add_cancel_fields_to_surgical_history" author="farouk">

    <addColumn tableName="surgical_history">

      <column name="status" type="varchar(50)" defaultValue="ACTIVE">
        <constraints nullable="false"/>
      </column>

      <column name="cancelled_by" type="varchar(50)"/>

      <column name="cancelled_date" type="timestamp"/>

      <column name="cancellation_reason" type="text"/>

    </addColumn>
    <sql><![CDATA[
      DROP INDEX IF EXISTS ux_surgical_history_patient_surgery_date_ci;
      ]]></sql>

    <sql><![CDATA[
      CREATE UNIQUE INDEX ux_surgical_history_patient_surgery_date_ci
        ON surgical_history (
                             patient_id,
                             lower(surgery),
                             date_of_surgery
          )
        WHERE status <> 'CANCELLED';
      ]]></sql>

  </changeSet>

</databaseChangeLog>
