<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="F00000000000002_add_cancel_fields_to_social_history" author="farouk">

    <addColumn tableName="social_history">

      <column name="status" type="varchar(50)" defaultValue="ACTIVE">
        <constraints nullable="false"/>
      </column>

      <column name="cancelled_by" type="varchar(50)"/>

      <column name="cancelled_date" type="timestamp"/>

      <column name="cancellation_reason" type="varchar(500)"/>

    </addColumn>

  </changeSet>

</databaseChangeLog>
